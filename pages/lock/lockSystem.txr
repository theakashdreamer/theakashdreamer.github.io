## 13) `ui/dashboard/DashboardActivity.kt`

```kotlin
package com.skysoftsolutions.locksystem.ui.dashboard

import android.content.Intent
import android.os.Bundle
import android.widget.Button
import android.widget.EditText
import android.widget.TextView
import android.widget.Toast
import androidx.appcompat.app.AppCompatActivity
import com.skysoftsolutions.locksystem.R
import com.skysoftsolutions.locksystem.device.DeviceOwnerManager
import com.skysoftsolutions.locksystem.permission.PermissionHelper
import com.skysoftsolutions.locksystem.ui.admin.DeviceAdminActivity
import com.skysoftsolutions.locksystem.ui.owner.DeviceOwnerInfoActivity
import com.skysoftsolutions.locksystem.ui.permission.PermissionActivity

class DashboardActivity : AppCompatActivity() {

    private lateinit var manager: DeviceOwnerManager

    private lateinit var tvAdminStatus: TextView
    private lateinit var tvOwnerStatus: TextView
    private lateinit var tvPermissionStatus: TextView
    private lateinit var etLockMessage: EditText

    private lateinit var btnEnableAdmin: Button
    private lateinit var btnPermissions: Button
    private lateinit var btnOwnerInfo: Button
    private lateinit var btnLockNow: Button
    private lateinit var btnSetMessage: Button
    private lateinit var btnApplyRestrictions: Button
    private lateinit var btnClearRestrictions: Button
    private lateinit var btnEnterKiosk: Button
    private lateinit var btnExitKiosk: Button
    private lateinit var btnRefresh: Button

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_dashboard)

        manager = DeviceOwnerManager(this)

        tvAdminStatus = findViewById(R.id.tvDashboardAdminStatus)
        tvOwnerStatus = findViewById(R.id.tvDashboardOwnerStatus)
        tvPermissionStatus = findViewById(R.id.tvDashboardPermissionStatus)
        etLockMessage = findViewById(R.id.etLockMessage)

        btnEnableAdmin = findViewById(R.id.btnDashboardEnableAdmin)
        btnPermissions = findViewById(R.id.btnDashboardPermissions)
        btnOwnerInfo = findViewById(R.id.btnDashboardOwnerInfo)
        btnLockNow = findViewById(R.id.btnDashboardLockNow)
        btnSetMessage = findViewById(R.id.btnDashboardSetMessage)
        btnApplyRestrictions = findViewById(R.id.btnDashboardApplyRestrictions)
        btnClearRestrictions = findViewById(R.id.btnDashboardClearRestrictions)
        btnEnterKiosk = findViewById(R.id.btnDashboardEnterKiosk)
        btnExitKiosk = findViewById(R.id.btnDashboardExitKiosk)
        btnRefresh = findViewById(R.id.btnDashboardRefresh)

        btnEnableAdmin.setOnClickListener {
            startActivity(Intent(this, DeviceAdminActivity::class.java))
        }

        btnPermissions.setOnClickListener {
            startActivity(Intent(this, PermissionActivity::class.java))
        }

        btnOwnerInfo.setOnClickListener {
            startActivity(Intent(this, DeviceOwnerInfoActivity::class.java))
        }

        btnLockNow.setOnClickListener {
            val result = manager.lockDeviceNow()
            showResult(result, "Device locked")
        }

        btnSetMessage.setOnClickListener {
            val message = etLockMessage.text.toString().trim()
            if (message.isEmpty()) {
                Toast.makeText(this, "Enter a message first", Toast.LENGTH_SHORT).show()
                return@setOnClickListener
            }
            val result = manager.setLostMessage(message)
            showResult(result, "Lock screen message updated")
        }

        btnApplyRestrictions.setOnClickListener {
            val result = manager.applyBaseRestrictions()
            showResult(result, "Base restrictions applied")
        }

        btnClearRestrictions.setOnClickListener {
            val result = manager.clearBaseRestrictions()
            showResult(result, "Base restrictions cleared")
        }

        btnEnterKiosk.setOnClickListener {
            val result = manager.enableKioskMode(this)
            showResult(result, "Kiosk mode started")
        }

        btnExitKiosk.setOnClickListener {
            val result = manager.disableKioskMode(this)
            showResult(result, "Kiosk mode stopped")
        }

        btnRefresh.setOnClickListener {
            refreshStatus()
        }

        refreshStatus()
    }

    override fun onResume() {
        super.onResume()
        refreshStatus()
    }

    private fun refreshStatus() {
        tvAdminStatus.text = if (manager.isAdminActive()) {
            "Device Admin: Enabled"
        } else {
            "Device Admin: Not enabled"
        }

        tvOwnerStatus.text = if (manager.isDeviceOwner()) {
            "Device Owner: Active"
        } else {
            "Device Owner: Not active"
        }

        tvPermissionStatus.text = if (PermissionHelper.hasAllRuntimePermissions(this)) {
            "Runtime Permissions: Granted"
        } else {
            "Runtime Permissions: Missing"
        }

        btnLockNow.isEnabled = manager.isAdminActive()
        btnSetMessage.isEnabled = manager.isDeviceOwner()
        btnApplyRestrictions.isEnabled = manager.isDeviceOwner()
        btnClearRestrictions.isEnabled = manager.isDeviceOwner()
        btnEnterKiosk.isEnabled = manager.isDeviceOwner()
    }

    private fun showResult(result: Result<Unit>, successMessage: String) {
        result.onSuccess {
            Toast.makeText(this, successMessage, Toast.LENGTH_SHORT).show()
            refreshStatus()
        }.onFailure {
            Toast.makeText(this, it.message ?: "Action failed", Toast.LENGTH_LONG).show()
            refreshStatus()
        }
    }
}
```

