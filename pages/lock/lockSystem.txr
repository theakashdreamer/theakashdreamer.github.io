## 18) `res/layout/activity_dashboard.xml`

```xml
<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Management Dashboard"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDashboardAdminStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:padding="14dp"
            android:background="#EEF3FF"
            android:text="Device Admin: Not enabled"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvDashboardOwnerStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:padding="14dp"
            android:background="#EEF3FF"
            android:text="Device Owner: Not active"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvDashboardPermissionStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:padding="14dp"
            android:background="#EEF3FF"
            android:text="Runtime Permissions: Missing"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/etLockMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="Enter lock screen message"
            android:inputType="textCapSentences" />

        <Button
            android:id="@+id/btnDashboardEnableAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Open Device Admin Screen" />

        <Button
            android:id="@+id/btnDashboardPermissions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Open Permission Screen" />

        <Button
            android:id="@+id/btnDashboardOwnerInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Open Device Owner Info" />

        <Button
            android:id="@+id/btnDashboardLockNow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Lock Device Now" />

        <Button
            android:id="@+id/btnDashboardSetMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Set Lock Message" />

        <Button
            android:id="@+id/btnDashboardApplyRestrictions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Apply Base Restrictions" />

        <Button
            android:id="@+id/btnDashboardClearRestrictions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Clear Base Restrictions" />

        <Button
            android:id="@+id/btnDashboardEnterKiosk"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Enter Kiosk Mode" />

        <Button
            android:id="@+id/btnDashboardExitKiosk"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Exit Kiosk Mode" />

        <Button
            android:id="@+id/btnDashboardRefresh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Refresh Status" />

    </LinearLayout>
</ScrollView>
```

