## 8) `receiver/BootCompletedReceiver.kt`

```kotlin
package com.skysoftsolutions.locksystem.receiver

import android.content.BroadcastReceiver
import android.content.Context
import android.content.Intent
import com.skysoftsolutions.locksystem.device.DeviceOwnerManager

class BootCompletedReceiver : BroadcastReceiver() {
    override fun onReceive(context: Context, intent: Intent) {
        if (intent.action != Intent.ACTION_BOOT_COMPLETED) return

        val manager = DeviceOwnerManager(context)

        if (manager.isDeviceOwner()) {
            manager.applyBaseRestrictions()
        }
    }
}
```

