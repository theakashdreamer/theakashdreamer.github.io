## 5) `data/SetupPreferences.kt`

```kotlin
package com.skysoftsolutions.locksystem.data

import android.content.Context

class SetupPreferences(context: Context) {

    private val prefs = context.getSharedPreferences("setup_prefs", Context.MODE_PRIVATE)

    fun isOwnerInfoDismissed(): Boolean {
        return prefs.getBoolean(KEY_OWNER_INFO_DISMISSED, false)
    }

    fun setOwnerInfoDismissed(value: Boolean) {
        prefs.edit().putBoolean(KEY_OWNER_INFO_DISMISSED, value).apply()
    }

    companion object {
        private const val KEY_OWNER_INFO_DISMISSED = "owner_info_dismissed"
    }
}
```

