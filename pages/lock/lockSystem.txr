## 12) `ui/owner/DeviceOwnerInfoActivity.kt`

```kotlin
package com.skysoftsolutions.locksystem.ui.owner

import android.content.ClipData
import android.content.ClipboardManager
import android.content.Context
import android.content.Intent
import android.os.Bundle
import android.widget.Button
import android.widget.TextView
import android.widget.Toast
import androidx.appcompat.app.AppCompatActivity
import com.skysoftsolutions.locksystem.R
import com.skysoftsolutions.locksystem.data.SetupPreferences
import com.skysoftsolutions.locksystem.device.DeviceOwnerManager
import com.skysoftsolutions.locksystem.ui.dashboard.DashboardActivity

class DeviceOwnerInfoActivity : AppCompatActivity() {

    private lateinit var manager: DeviceOwnerManager
    private lateinit var prefs: SetupPreferences

    private lateinit var statusText: TextView
    private lateinit var commandText: TextView
    private lateinit var copyButton: Button
    private lateinit var refreshButton: Button
    private lateinit var continueAdminModeButton: Button

    private val adbCommand =
        "adb shell dpm set-device-owner com.skysoftsolutions.locksystem/.admin.OrganizationDeviceAdminReceiver"

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_device_owner_info)

        manager = DeviceOwnerManager(this)
        prefs = SetupPreferences(this)

        statusText = findViewById(R.id.tvOwnerCurrentStatus)
        commandText = findViewById(R.id.tvOwnerCommand)
        copyButton = findViewById(R.id.btnCopyOwnerCommand)
        refreshButton = findViewById(R.id.btnRefreshOwnerStatus)
        continueAdminModeButton = findViewById(R.id.btnContinueAdminMode)

        commandText.text = adbCommand

        copyButton.setOnClickListener {
            val clipboard = getSystemService(Context.CLIPBOARD_SERVICE) as ClipboardManager
            clipboard.setPrimaryClip(ClipData.newPlainText("adb_command", adbCommand))
            Toast.makeText(this, "ADB command copied", Toast.LENGTH_SHORT).show()
        }

        refreshButton.setOnClickListener {
            if (manager.isDeviceOwner()) {
                Toast.makeText(this, "Device owner is active", Toast.LENGTH_SHORT).show()
                openDashboard()
            } else {
                refreshUi()
                Toast.makeText(this, "Device owner is still not active", Toast.LENGTH_SHORT).show()
            }
        }

        continueAdminModeButton.setOnClickListener {
            prefs.setOwnerInfoDismissed(true)
            openDashboard()
        }

        refreshUi()
    }

    override fun onResume() {
        super.onResume()
        refreshUi()
    }

    private fun refreshUi() {
        statusText.text = if (manager.isDeviceOwner()) {
            "Device Owner: Active"
        } else {
            "Device Owner: Not active"
        }
    }

    private fun openDashboard() {
        startActivity(Intent(this, DashboardActivity::class.java))
        finish()
    }
}
```

