## 10) `ui/admin/DeviceAdminActivity.kt`

```kotlin
package com.skysoftsolutions.locksystem.ui.admin

import android.app.Activity
import android.app.admin.DevicePolicyManager
import android.content.Intent
import android.os.Bundle
import android.widget.Button
import android.widget.TextView
import android.widget.Toast
import androidx.activity.result.contract.ActivityResultContracts
import androidx.appcompat.app.AppCompatActivity
import com.google.android.material.card.MaterialCardView
import com.skysoftsolutions.locksystem.R
import com.skysoftsolutions.locksystem.admin.OrganizationDeviceAdminReceiver
import com.skysoftsolutions.locksystem.device.DeviceOwnerManager
import com.skysoftsolutions.locksystem.navigation.AppRouter

class DeviceAdminActivity : AppCompatActivity() {

    private lateinit var statusText: TextView
    private lateinit var ownerText: TextView
    private lateinit var enableButton: Button
    private lateinit var continueButton: Button
    private lateinit var statusCard: MaterialCardView

    private lateinit var manager: DeviceOwnerManager

    private val adminLauncher = registerForActivityResult(
        ActivityResultContracts.StartActivityForResult()
    ) { result ->
        refreshUi()
        if (result.resultCode == Activity.RESULT_OK && manager.isAdminActive()) {
            routeNext()
        }
    }

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_device_admin)

        manager = DeviceOwnerManager(this)

        statusText = findViewById(R.id.tvAdminStatus)
        ownerText = findViewById(R.id.tvOwnerStatus)
        enableButton = findViewById(R.id.btnEnableAdmin)
        continueButton = findViewById(R.id.btnContinueAfterAdmin)
        statusCard = findViewById(R.id.cardAdminStatus)

        enableButton.setOnClickListener {
            openAdminEnableScreen()
        }

        continueButton.setOnClickListener {
            if (!manager.isAdminActive()) {
                Toast.makeText(this, "Enable device admin first", Toast.LENGTH_SHORT).show()
                return@setOnClickListener
            }
            routeNext()
        }

        refreshUi()
    }

    override fun onResume() {
        super.onResume()
        refreshUi()
    }

    private fun openAdminEnableScreen() {
        val intent = Intent(DevicePolicyManager.ACTION_ADD_DEVICE_ADMIN).apply {
            putExtra(
                DevicePolicyManager.EXTRA_DEVICE_ADMIN,
                OrganizationDeviceAdminReceiver.getComponentName(this@DeviceAdminActivity)
            )
            putExtra(
                DevicePolicyManager.EXTRA_ADD_EXPLANATION,
                "Allow this app to manage lock, kiosk, and security actions on this device."
            )
        }
        adminLauncher.launch(intent)
    }

    private fun refreshUi() {
        val isAdmin = manager.isAdminActive()
        val isOwner = manager.isDeviceOwner()

        statusText.text = if (isAdmin) {
            "Device Admin: Enabled"
        } else {
            "Device Admin: Not enabled"
        }

        ownerText.text = if (isOwner) {
            "Device Owner: Active"
        } else {
            "Device Owner: Not active"
        }

        enableButton.isEnabled = !isAdmin
        continueButton.isEnabled = isAdmin
    }

    private fun routeNext() {
        startActivity(AppRouter.nextIntent(this))
        finish()
    }
}
```

