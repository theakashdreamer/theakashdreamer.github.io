## 11) `ui/permission/PermissionActivity.kt`

```kotlin
package com.skysoftsolutions.locksystem.ui.permission

import android.os.Bundle
import android.widget.Button
import android.widget.TextView
import android.widget.Toast
import androidx.activity.result.contract.ActivityResultContracts
import androidx.appcompat.app.AppCompatActivity
import com.skysoftsolutions.locksystem.R
import com.skysoftsolutions.locksystem.navigation.AppRouter
import com.skysoftsolutions.locksystem.permission.PermissionHelper

class PermissionActivity : AppCompatActivity() {

    private lateinit var permissionSummary: TextView
    private lateinit var grantButton: Button
    private lateinit var continueButton: Button

    private val permissionLauncher = registerForActivityResult(
        ActivityResultContracts.RequestMultiplePermissions()
    ) {
        refreshUi()
    }

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_permission)

        permissionSummary = findViewById(R.id.tvPermissionSummary)
        grantButton = findViewById(R.id.btnGrantPermissions)
        continueButton = findViewById(R.id.btnContinueAfterPermission)

        grantButton.setOnClickListener {
            val missing = PermissionHelper.missingRuntimePermissions(this)
            if (missing.isEmpty()) {
                Toast.makeText(this, "All permissions already granted", Toast.LENGTH_SHORT).show()
            } else {
                permissionLauncher.launch(missing.toTypedArray())
            }
        }

        continueButton.setOnClickListener {
            if (!PermissionHelper.hasAllRuntimePermissions(this)) {
                Toast.makeText(this, "Grant all required permissions first", Toast.LENGTH_SHORT).show()
                return@setOnClickListener
            }
            startActivity(AppRouter.nextIntent(this))
            finish()
        }

        refreshUi()
    }

    override fun onResume() {
        super.onResume()
        refreshUi()
    }

    private fun refreshUi() {
        val missing = PermissionHelper.missingRuntimePermissions(this)

        permissionSummary.text = if (missing.isEmpty()) {
            "All required runtime permissions are granted."
        } else {
            buildString {
                append("Missing runtime permissions:\n\n")
                missing.forEach { append("• ").append(it).append("\n") }
            }
        }

        grantButton.isEnabled = missing.isNotEmpty()
        continueButton.isEnabled = missing.isEmpty()
    }
}
```

