        <Button
            android:id="@+id/btnContinueAfterPermission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Continue" />

    </LinearLayout>
</ScrollView>
